# Copy to .env.local and fill in real values for local development:
#   cp .env.example .env.local
#
# .env.local is git-ignored; this file is the template committed to the repo.
# Validate with: python3 scripts/validate-env.py

# ---------------------------------------------------------------------------
# Database & cache
# ---------------------------------------------------------------------------
# SQLAlchemy URL — use the psycopg (v3) driver dialect for the backend.
DATABASE_URL=postgresql+psycopg://postgres:devpassword@localhost:5432/digital_twin_dev
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Auth (Phase 1)
# ---------------------------------------------------------------------------
# JWT_SECRET must be replaced with a strong random value before any non-dev use.
JWT_SECRET=dev-secret-only-for-testing-min-32b
JWT_EXPIRY=86400
JWT_ALGORITHM=HS256
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_SECONDS=900
# Allow login before email verification (convenient for local dev).
AUTH_ALLOW_UNVERIFIED_LOGIN=true

# OAuth (optional — empty means endpoints return 503 until configured)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=1
DEBUG=true
LOG_LEVEL=DEBUG
# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Email (console logs messages in development)
EMAIL_BACKEND=console
EMAIL_FROM=noreply@localhost

# ---------------------------------------------------------------------------
# External services (placeholders until Phase 1+)
# ---------------------------------------------------------------------------
CLAUDE_API_KEY=sk-test
CLAUDE_MODEL=claude-sonnet-4-20250514
PUSHOVER_APP_TOKEN=test-token
# Fernet key for field-level encryption (generate with cryptography.fernet.Fernet.generate_key())
ENCRYPTION_KEY=
S3_BUCKET=digital-twin-dev
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ---------------------------------------------------------------------------
# Celery (async workers — CV processing, later notifications)
# ---------------------------------------------------------------------------
# Defaults use Redis DBs 0 (broker) and 1 (results). Override if needed.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Tests force eager mode; leave false for real worker processes.
CELERY_TASK_ALWAYS_EAGER=false

# ---------------------------------------------------------------------------
# Chat (visitor digital twin sessions)
# ---------------------------------------------------------------------------
CHAT_SESSION_TTL_MINUTES=30
CHAT_RATE_LIMIT_PER_HOUR=50
CHAT_RATE_LIMIT_WINDOW_SECONDS=3600
CHAT_SSE_CHUNK_SIZE=48

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_DEBUG=true
