# Copy to .env.local and fill in real values for local development:
#   cp .env.example .env.local
#
# .env.local is git-ignored; this file is the template committed to the repo.
# Validate with: python3 scripts/validate-env.py

# ---------------------------------------------------------------------------
# Database & cache
# ---------------------------------------------------------------------------
# SQLAlchemy URL — use the psycopg (v3) driver dialect for the backend.
DATABASE_URL=postgresql+psycopg://postgres:devpassword@localhost:5432/digital_twin_dev
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Auth (Phase 1)
# ---------------------------------------------------------------------------
# JWT_SECRET must be replaced with a strong random value before any non-dev use.
JWT_SECRET=dev-secret-only-for-testing
JWT_EXPIRY=86400

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=1
DEBUG=true
LOG_LEVEL=DEBUG

# ---------------------------------------------------------------------------
# External services (placeholders until Phase 1+)
# ---------------------------------------------------------------------------
CLAUDE_API_KEY=sk-test
PUSHOVER_APP_TOKEN=test-token
# Fernet key for field-level encryption (generate with cryptography.fernet.Fernet.generate_key())
ENCRYPTION_KEY=
S3_BUCKET=digital-twin-dev
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_DEBUG=true
