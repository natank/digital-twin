{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Uvicorn",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["src.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}/apps/backend",
      "envFile": "${workspaceFolder}/.env.local",
      "python": "${workspaceFolder}/apps/backend/.venv/bin/python",
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "Backend: Current Test File (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "cwd": "${workspaceFolder}/apps/backend",
      "envFile": "${workspaceFolder}/.env.local",
      "python": "${workspaceFolder}/apps/backend/.venv/bin/python",
      "justMyCode": true
    },
    {
      "name": "Scripts: validate-env",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/validate-env.py",
      "args": ["--check-services"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
