# EditorConfig — https://editorconfig.org
# Shared baseline for VS Code, JetBrains, Vim, etc.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}]
indent_size = 2

[*.{json,jsonc,yml,yaml}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[*.sql]
indent_size = 2

[*.toml]
indent_size = 4
